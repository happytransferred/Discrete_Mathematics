generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String
  role         String
  createdAt    DateTime      @default(now())
  teachClasses Class[]       @relation("TeacherClasses")
  memberships  ClassMember[]
  submissions  Submission[]
  templates    AssignmentTemplate[]
}

model Class {
  id          String        @id @default(cuid())
  name        String
  code        String        @unique
  teacherId   String
  teacher     User          @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: Cascade)
  assignments Assignment[]
  members     ClassMember[]
  createdAt   DateTime      @default(now())
}

model ClassMember {
  id        String   @id @default(cuid())
  classId   String
  studentId String
  joinedAt  DateTime @default(now())
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
}

model Assignment {
  id                String               @id @default(cuid())
  classId           String
  templateId        String?
  title             String
  description       String?
  dueDate           DateTime?
  allowResubmission Boolean              @default(true)
  totalScore        Int                  @default(100)
  createdAt         DateTime             @default(now())
  class             Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  template          AssignmentTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  questions         AssignmentQuestion[]
  submissions       Submission[]
}

model AssignmentQuestion {
  id                 String             @id @default(cuid())
  assignmentId       String
  orderIndex         Int
  title              String
  prompt             String
  promptImagePath    String?
  type               String
  options            String?
  referenceAnswer    String?
  referenceImagePath String?
  gradingRubric      String?
  maxScore           Int
  assignment         Assignment         @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  answers            SubmissionAnswer[]

  @@unique([assignmentId, orderIndex])
}

model AssignmentTemplate {
  id                String                      @id @default(cuid())
  teacherId         String
  title             String
  description       String?
  allowResubmission Boolean                     @default(true)
  totalScore        Int                         @default(100)
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  teacher           User                        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  questions         AssignmentTemplateQuestion[]
  assignments       Assignment[]
}

model AssignmentTemplateQuestion {
  id                 String              @id @default(cuid())
  templateId         String
  orderIndex         Int
  title              String
  prompt             String
  promptImagePath    String?
  type               String
  options            String?
  referenceAnswer    String?
  referenceImagePath String?
  gradingRubric      String?
  maxScore           Int
  template           AssignmentTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, orderIndex])
}

model Submission {
  id            String             @id @default(cuid())
  assignmentId  String
  studentId     String
  attemptNumber Int                @default(1)
  gradingStatus String             @default("AI_GRADED")
  aiSummary     String?
  overallScore  Int                @default(0)
  maxScore      Int                @default(100)
  summary       String             @default("")
  aiGradingResult String?
  gradingResult String
  reviewedAt    DateTime?
  createdAt     DateTime           @default(now())
  assignment    Assignment         @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student       User               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers       SubmissionAnswer[]

  @@unique([assignmentId, studentId, attemptNumber])
}

model SubmissionAnswer {
  id             String             @id @default(cuid())
  submissionId   String
  questionId     String
  textAnswer     String?
  selectedOption String?
  imagePath      String?
  aiScore        Int?
  aiFeedback     String?
  teacherScore   Int?
  teacherFeedback String?
  score          Int
  maxScore       Int
  feedback       String
  submission     Submission         @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question       AssignmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, questionId])
}
